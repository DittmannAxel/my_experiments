# =============================================================================
# Robot Digital Twin PoC — environment template
# Copy to .env and fill in. .env is gitignored.
# =============================================================================

# --- vLLM (bare-metal on host, NOT in this stack) ---
# Discover model id with: curl http://<HOST_IP>:8000/v1/models  (run on the LAN)
VLLM_BASE_URL=http://host.docker.internal:8000/v1
VLLM_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-FP8

# --- OPC UA server ---
OPCUA_USER=axel
OPCUA_PASSWORD=changeme-please

# Set to e.g. axis4_overheat to trigger an anomaly on startup; empty = none
INJECT_ANOMALY=

# --- Traefik / TLS ---
STACK_HOSTNAME=stack.local

# --- InfluxDB ---
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=changeme-please
INFLUXDB_ORG=axel
INFLUXDB_BUCKET=robot
# Generate once:  openssl rand -hex 32
INFLUXDB_ADMIN_TOKEN=replace-me-with-32-byte-hex

# --- Grafana ---
GF_SECURITY_ADMIN_PASSWORD=changeme-please

# --- pgvector ---
PGVECTOR_USER=rag
PGVECTOR_PASSWORD=changeme-please
PGVECTOR_DB=rag

# --- GPU split ---
# vLLM on host typically pins to GPU 0 with CUDA_VISIBLE_DEVICES=0.
# Omniverse Kit uses GPU 1 (NVIDIA_VISIBLE_DEVICES=1 in compose).
# If the host vLLM uses --tensor-parallel-size 2 (both GPUs),
# stop vLLM before bringing up the omniverse-kit service.
OMNIVERSE_GPU_ID=1
