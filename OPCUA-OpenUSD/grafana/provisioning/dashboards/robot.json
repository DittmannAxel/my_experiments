  "panels": [
    {
      "type": "timeseries",
      "title": "Axis Positions (deg)",
      "id": 1,
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "influxdb", "uid": "InfluxDB"},
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"robot\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"axis\" and r.metric == \"position\")\n  |> filter(fn: (r) => r._field == \"axis1_pos\" or r._field == \"axis2_pos\" or r._field == \"axis3_pos\" or r._field == \"axis4_pos\" or r._field == \"axis5_pos\" or r._field == \"axis6_pos\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n  |> yield(name: \"position\")"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "degree",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "type": "timeseries",
      "title": "Motor Temperatures (°C) — threshold 90°C",
      "id": 2,
      "gridPos": {"h": 9, "w": 18, "x": 0, "y": 9},
      "datasource": {"type": "influxdb", "uid": "InfluxDB"},
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"robot\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"axis\" and r.metric == \"motor_temp\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n  |> yield(name: \"motor_temp\")"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red",    "value": 90}
            ]
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "lineWidth": 2,
            "fillOpacity": 5,
            "thresholdsStyle": {"mode": "line"}
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi"}
      }
    },
