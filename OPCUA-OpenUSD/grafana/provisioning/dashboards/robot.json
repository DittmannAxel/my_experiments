          "query": "from(bucket: \"robot\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"scalar\" and r._field == \"cycle_counter\")\n  |> last()"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "decimals": 0,
