# Omniverse Kit App container — Robot Twin Viewer.
#
# This Dockerfile is a fallback for environments where the kit-app-template's
# native `./repo.sh package_container` cannot be run (e.g. CI runners). The
# preferred build path is documented in this directory's README.md and uses
# `repo_kit_package_container` directly. That tooling produces a richer image
# (split base/app layers, artifact collector venv, regkeys.txt, etc.).
#
# What this file does instead: take the already-built `_build/linux-x86_64/release`
# tree from the kit-app-template repo (mounted/copied at build time) and bake
# it into the same NVIDIA Omniverse base image that the official tool uses.
#
# Build context expected: kit-app-template repo root.
#
#   docker build \
#     --build-arg KIT_BUILD_DIR=_build/linux-x86_64/release \
#     --build-arg KIT_APP=axel.robot_twin_viewer_streaming \
#     -t axel/robot_twin_viewer:0.1.0 \
#     -f /path/to/this/Dockerfile \
#     /home/<user>/dev/git/omniverse/kit-app-template/
#
# Pulling the base image is unauthenticated for the public Omniverse base
# layer, but if NGC ever requires auth, run `docker login nvcr.io` first.

ARG OV_BASE_TAG=2026.2.3
FROM nvcr.io/nvidia/omniverse/ov-base-ubuntu-22:${OV_BASE_TAG}

USER root

RUN useradd --create-home --shell /bin/bash ubuntu || true \
 && usermod -aG sudo ubuntu \
 && mkdir -p /etc/sudoers.d/ \
 && echo "ubuntu ALL=(ALL:ALL) NOPASSWD: ALL" > /etc/sudoers.d/ubuntu \
 && mkdir -p /home/ubuntu/.config \
 && echo "SenderTimeout=1000000" > /home/ubuntu/.config/regkeys.txt \
 && chown root:root /home/ubuntu/.config/regkeys.txt \
 && chmod 555 /home/ubuntu/.config/regkeys.txt

ARG KIT_BUILD_DIR=_build/linux-x86_64/release
ARG KIT_APP=axel.robot_twin_viewer_streaming

WORKDIR /app
COPY --chown=root:root --chmod=555 ${KIT_BUILD_DIR}/ /app/

USER ubuntu
WORKDIR /app

RUN mkdir -p /home/ubuntu/.cache/ov \
 && mkdir -p /home/ubuntu/.local/share/ov \
 && mkdir -p /home/ubuntu/.nvidia-omniverse/config

ENV KIT_APP=${KIT_APP}
ENV OMNI_KIT_ALLOW_ROOT=1
ENV ACCEPT_EULA=Y
ENV PRIVACY_CONSENT=Y

# Livestream port (omni.kit.livestream.app HTTP signaling) + WebRTC UDP/TCP range.
EXPOSE 8011/tcp \
       47995-48012/udp \
       47995-48012/tcp \
       49100/tcp

# Default entrypoint launches the streaming kit app. The kit launcher script
# is generated by `repo.sh build` at /app/<KIT_APP>.kit.sh.
ENTRYPOINT ["/bin/sh", "-c", "exec /app/${KIT_APP}.kit.sh \"$@\"", "--"]
